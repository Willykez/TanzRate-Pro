<?xml version="1.0" encoding="utf-8"?>
<!--
  TanzRate Home-Screen Widget layout.
  The widget renders entirely as a Bitmap drawn in RateWidget.java
  and placed into this ImageView — giving us full pixel control.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@string/widget_description" />

</FrameLayout>
